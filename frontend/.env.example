# Copy this file to .env.local and fill in your values.
# The .env.local file is git-ignored and must NEVER be committed.
# In Azure Static Web Apps, set these as Application Settings.

# Full URL of the backend API (Azure App Service URL, no trailing slash).
# Example: https://api-inmo-sena-thomas.azurewebsites.net
# Leave empty to use the Vite dev-server proxy (/api → http://localhost:8000).
VITE_API_URL=

# Google OAuth 2.0 client ID — required for the "Continuar con Google" button.
# Obtain from https://console.cloud.google.com/ → APIs & Services → Credentials.
VITE_GOOGLE_CLIENT_ID=
