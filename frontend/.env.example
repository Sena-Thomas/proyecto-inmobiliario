# Copy this file to .env.local and fill in your values.
# The .env.local file is git-ignored and must NEVER be committed.
# In Azure Static Web Apps, set these as Application Settings (and as GitHub
# repository secrets so they are injected at build time by GitHub Actions).

# Full URL of the backend API (Azure App Service URL, no trailing slash).
# Example: https://api-inmo-sena-thomas.azurewebsites.net
# Leave empty to use the Vite dev-server proxy (/api → http://localhost:8000).
VITE_API_URL=

# Google OAuth 2.0 client ID — required for the "Continuar con Google" button.
# Obtain from https://console.cloud.google.com/ → APIs & Services → Credentials.
VITE_GOOGLE_CLIENT_ID=

# WhatsApp phone number for the contact button (country code + number, no +).
# Example for Colombia: 573105597895
VITE_MONICA_PHONE=

# Social media URLs shown in the hero section.
VITE_FACEBOOK_URL=
VITE_INSTAGRAM_URL=
